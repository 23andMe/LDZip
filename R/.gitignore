# R specific files to ignore
# adapted from 

# PDF files that are generated by R CMD Rd2pdf
/inst/doc/

# Manual .Rd files generated by oxygen
# /man/*Rd

#Rd2pdf temp files
/.Rd2pdf*

#Namespace file (auto-generated by rOxygen2)
# NAMESPACE

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# Rcpp export files
src/RcppExports.cpp
R/RcppExports.R

# User-specific files
.Ruserdata

# Output files from R CMD build
/*.tar.gz

# .so and .o files from Rcpp
src/*o

# test data files from tinytest
tests/data/*

# Output files from R CMD check
/*.Rcheck/
*.Rcheck*

# RStudio files
.Rproj.user/

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron